{
  "name": "mdvault",
  "private": true,
  "version": "0.1.0",
  "description": "Headless markdown-vault data layer for Bun — CRUD + SQLite index, no Obsidian required",
  "type": "module",
  "license": "MIT",
  "author": "Ivan Kalinichenko",
  "engines": {
    "bun": ">=1.1.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "!src/**/*.test.ts",
    "!src/**/__tests__/**"
  ],
  "scripts": {
    "prepublishOnly": "echo 'mdvault is not publishable yet: @/ import aliases require a bundling/tsc-alias step first (see CLAUDE.md)'; exit 1",
    "test": "bun test",
    "check": "biome check . && tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  }
}
