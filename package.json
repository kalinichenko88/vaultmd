{
  "name": "mdvault",
  "version": "0.1.0",
  "description": "Headless markdown-vault data layer for Bun — CRUD + SQLite index, no Obsidian required",
  "type": "module",
  "license": "MIT",
  "author": "Ivan Kalinichenko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalinichenko88/mdvault.git"
  },
  "homepage": "https://github.com/kalinichenko88/mdvault#readme",
  "bugs": {
    "url": "https://github.com/kalinichenko88/mdvault/issues"
  },
  "keywords": [
    "markdown",
    "vault",
    "notes",
    "bun",
    "sqlite",
    "backlinks",
    "wikilinks",
    "frontmatter",
    "full-text-search",
    "obsidian",
    "headless",
    "esm"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "smoke": "bash scripts/smoke-pack.sh",
    "test": "bun test",
    "check": "biome check . && tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "latest",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3"
  }
}
